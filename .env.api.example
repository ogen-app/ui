# Ogen local stack configuration — consumed by docker-compose.yml.
# Copy this file and fill in real values (the copy is gitignored):
#   cp .env.example .env

# --- API service ---
ADDR=:9001
DATABASE_DSN=postgres://ogen:ogen@postgres:5432/ogen?sslmode=disable

# Embeddings (CON-101): hosted Gemini Embedding 2. Leave GEMINI_API_KEY empty to
# disable embedding — asset saves still succeed, but no vectors are written and
# semantic search returns nothing. EMBED_DIMENSIONS must match the
# assets_chunks.embedding halfvec(N) column.
GEMINI_API_KEY=
EMBED_MODEL=gemini-embedding-2
EMBED_DIMENSIONS=3072

# Envelope-encryption KEK directory (mounted from the ogen-keys volume).
OGEN_KEK_PATH=/var/lib/ogen/keys

# Object storage (Cloudflare R2 / S3-compatible).
# Leave STORAGE_ENDPOINT empty to disable image/PDF uploads.
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_PUBLIC_URL=https://pub-<hash>.r2.dev

# Zernio post-OAuth redirect target.
ZERNIO_REDIRECT_URL=http://localhost:9001

# --- Postgres service ---
POSTGRES_USER=ogen
POSTGRES_PASSWORD=ogen
POSTGRES_DB=ogen
