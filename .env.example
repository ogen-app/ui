# Ogen UI — build-time configuration. Copy to .env.local for local overrides.

# Absolute API origin. Leave EMPTY (default) to use relative /api requests,
# which are proxied to the API by:
#   - the Vite dev server (see vite.config.ts; defaults to http://localhost:9001)
#   - Caddy in the deployed container (see Caddyfile)
# Set to an absolute origin (e.g. https://api.getogen.com) only to call the API
# cross-origin directly — the API must then allow this origin via CORS with
# credentials (CORS_ALLOWED_ORIGINS).
VITE_API_URL=

# Local dev only: where the Vite dev server proxies /api (see vite.config.ts).
# API_URL=http://localhost:9001
